// From docs/data-models.md (essential parts for Auth.js and basic user)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

enum Role {
  USER
  ORGANIZER
  TALENT
  ADMIN
}

enum RequestedRole {
  ORGANIZER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConventionStatus {
  DRAFT
  UPCOMING
  ACTIVE
  PAST
  CANCELLED
}

enum ConventionType {
  GAMING
  ANIME
  COMIC
  SCI_FI
  FANTASY
  HORROR
  GENERAL
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?   // Display name
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String? // Added based on Story 1.2 needs, useful to define early for Auth.js
  roles         Role[]    @default([USER])
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bio           String?   // Short biography
  roleApplications RoleApplication[]
  organizedConventions Convention[] @relation("OrganizedBy")
  roleRequests  RoleRequest[]
  conventionSeries ConventionSeries[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model RoleApplication {
  id            String            @id @default(cuid())
  userId        String
  requestedRole RequestedRole
  status        ApplicationStatus @default(PENDING)
  // message     String? // Optional: for application notes or rejection reasons

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, requestedRole]) // A user can only have one pending application for a specific role
}

model ConventionSeries {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String?
  logoUrl       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  organizer     User      @relation(fields: [organizerUserId], references: [id])
  organizerUserId String
  conventions   Convention[]
}

model Convention {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  startDate          DateTime
  endDate            DateTime
  city               String
  stateAbbreviation  String?
  stateName          String?
  country            String
  venueName          String?
  description        String?   @db.Text
  websiteUrl         String?
  organizerUserId    String
  organizer          User      @relation("OrganizedBy", fields: [organizerUserId], references: [id])
  conventionSeriesId String?   // Made optional for migration
  status             ConventionStatus
  type               ConventionType @default(GENERAL)
  bannerImageUrl     String?
  galleryImageUrls   String[]  @default([])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  series             ConventionSeries @relation(fields: [seriesId], references: [id])
  seriesId           String
}

model RoleRequest {
  id            String    @id @default(cuid())
  userId        String
  requestedRole Role
  status        RequestStatus @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, requestedRole]) // A user can only have one pending request per role
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
} 